# copy to .env and update values
# use PostgreSQL connection string or sqlite file path
DATABASE_URL=postgres://user:password@localhost:5432/krishishield_db
# alternatively for sqlite: sqlite:./database.sqlite
PORT=5000
JWT_SECRET=your_jwt_secret_here

# OpenWeatherMap key used for weather endpoints
# Obtain one at https://openweathermap.org/api
WEATHER_API_KEY=a823de53bca44e6615a464f4b0b846f6

# Hugging Face Hosted Inference API
# Set HF_API_TOKEN to your Hugging Face access token (do NOT commit it)
# Set HF_MODEL_ID to the model you want to use for image classification, e.g.:
# HF_MODEL_ID=your-username/your-plant-disease-model
HF_API_TOKEN=your_hf_token_here
HF_MODEL_ID=your-model-id-here
